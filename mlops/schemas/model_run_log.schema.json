{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "model_run_log",
  "type": "object",
  "required": [
    "run_id",
    "run_timestamp",
    "git_commit_hash",
    "code_version",
    "config_version",
    "dataset_version",
    "logic_version",
    "output_version",
    "environment",
    "status",
    "executed_by"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "run_timestamp": { "type": "string", "format": "date-time" },
    "git_commit_hash": { "type": "string" },
    "code_version": { "type": "string" },
    "config_version": { "type": "string" },
    "dataset_version": { "type": "string" },
    "logic_version": { "type": "string" },
    "output_version": { "type": "string" },
    "environment": { "type": "string", "enum": ["sandbox", "staging", "validation", "prod"] },
    "status": { "type": "string", "enum": ["started", "succeeded", "failed"] },
    "executed_by": { "type": "string" },
    "input_blob_path": { "type": "string" },
    "compute_target": { "type": "string" },
    "trigger_type": { "type": "string" },
    "model_repo": { "type": "string" },
    "model_ref": { "type": "string" },
    "model_commit_sha": { "type": "string" },
    "monitoring_config_path": { "type": "string" },
    "monitoring_config_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "storage_uri": { "type": "string" },
    "comments": { "type": "string" }
  },
  "additionalProperties": false
}
