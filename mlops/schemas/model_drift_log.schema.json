{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "model_drift_log",
  "type": "object",
  "required": [
    "drift_run_id",
    "monitoring_stage",
    "variable_name",
    "variable_type",
    "drift_metric",
    "drift_value",
    "p_value",
    "threshold_yellow",
    "threshold_red",
    "drift_status",
    "recommended_action",
    "monitoring_scope"
  ],
  "properties": {
    "drift_run_id": { "type": "string" },
    "monitoring_stage": { "type": "string" },
    "variable_name": { "type": "string" },
    "variable_type": { "type": "string", "enum": ["price", "quantity", "output"] },
    "drift_metric": { "type": "string" },
    "drift_value": { "type": "number" },
    "p_value": { "type": "number" },
    "threshold_yellow": { "type": "number" },
    "threshold_red": { "type": "number" },
    "drift_status": { "type": "string", "enum": ["Green", "Yellow", "Red"] },
    "recommended_action": { "type": "string" },
    "monitoring_scope": { "type": "string" }
  },
  "additionalProperties": false
}
